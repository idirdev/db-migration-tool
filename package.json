{
  "name": "db-migration-tool",
  "version": "1.0.0",
  "description": "Database migration engine with schema DSL and seeding support",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "migrate": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "test": "jest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.0",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/pg": "^8.11.0",
    "typescript": "^5.4.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.0"
  },
  "keywords": ["database", "migration", "schema", "cli", "postgresql"],
  "license": "MIT"
}
